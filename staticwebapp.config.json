{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.png", "/*.svg", "/*.ico", "/sw.js", "/workbox-*.js", "/manifest.webmanifest", "/registerSW.js"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  }
}
